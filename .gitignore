# ------------------------------------------------
# Author: Ryo Nakagami
# Revised: 2026-07-09
# File: TypeScript / VSCode Extension .gitignore
# Description:
#   This file specifies intentionally untracked files to ignore in the Git repository.
#   It includes:
#     - Temporary files (e.g., *.tmp, *.bak, *~)
#     - Log files and directories (e.g., logs/, *.log)
#     - Environment-specific files (e.g., .env, env/)
#     - Compiled binaries (e.g., *.bin, *.exe)
#     - IDE-specific files (e.g., .vscode/, .idea/)
#     - Build artifacts (e.g., tmp/, dist/, build/)
#     - Node.js dependencies (e.g., node_modules/)
#     - VSCode extension artifacts (e.g., *.vsix, .vscode-test/)
#     - Vite / webview build output
#     - Files generated by BFG Repo-Cleaner (e.g., ..bfg-report, bfg_check_list/)
#     - Temporary scripts generated during execution tests (e.g., *.test.sh)
#     - Sandbox directories (e.g., sandbox/)
# ------------------------------------------------

# ---- Ignore cache/temporary files ----
.DS_Store
*.swp
*.swo
*~
*.tmp
*.bak

# ---- log files and directories ----
logs/
*.log
*.out
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Temporary scripts generated during execution tests ----
*.test.sh

# ---- Environment-specific files and directories ----
.env
.env.*
!.env.example
env/
ENV/
env.bak/
*.gpg

# ---- Compiled binary files ----
*.bin
*.exe

# ---- temporary directories to ignore ----
tmp/
sandbox/

# ---- Node.js dependencies ----
node_modules/

# ---- Build artifacts ----
dist/
build/
out/
*.tsbuildinfo

# ---- VSCode extension artifacts ----
*.vsix
.vscode-test/
.vscode-test-web/

# ---- Vite / webview build output ----
.vite/
vscode-extension/dist/
vscode-extension/webview/dist/
vscode-extension/**/dist/

# ---- IDE-specific files and directories ----
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml

# ---- Files and directories generated by BFG Repo-Cleaner ----
..bfg-report
bfg_check_list/
